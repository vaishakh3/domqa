{
  "manifest_version": 3,
  "name": "DOMQA",
  "version": "0.1.0",
  "description": "Capture element-level frontend issues with technical context.",
  "permissions": ["storage", "activeTab", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": { "default_title": "DOMQA", "default_popup": "popup.html" },
  "background": { "service_worker": "dist/background/index.js", "type": "module" },
  "content_scripts": [{ "matches": ["<all_urls>"], "js": ["dist/content/index.js"], "run_at": "document_idle" }]
}
