{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "allowJs": false,
    "incremental": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {"@/*": ["./*"]}
  },
  "include": ["**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
